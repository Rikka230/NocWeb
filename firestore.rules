rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdminEmail() {
      return signedIn()
        && request.auth.token.email in [
          "viard.antony83@gmail.com",
          "Viard.antony83@gmail.com",
          "nocx230@hotmail.com"
        ];
    }

    function isAdmin() {
      return isAdminEmail()
        || (signedIn() && exists(/databases/$(database)/documents/nocxAdmins/$(request.auth.uid)));
    }

    match /trustedClients/{clientId} {
      allow read: if resource.data.visible == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /clientReviews/{reviewId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create: if request.resource.data.published == false
        && request.resource.data.status == "pending"
        && request.resource.data.author is string
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 700;
      allow update, delete: if isAdmin();
    }

    match /nocxAdmins/{uid} {
      allow read, write: if isAdmin();
    }
  }
}
